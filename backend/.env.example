# ════════════════════════════════════════════════════════════════
#  Agentic AI Workflow for Aeroplanes — Environment Variables
#  ✅ NO PAID API KEY REQUIRED — runs 100% free by default
# ════════════════════════════════════════════════════════════════

# ── OPTIONAL: Groq Free-Tier LLM (smarter query parsing) ────────
# Groq is completely FREE — no credit card needed.
# Free tier: 14,400 requests/day on llama3-8b-8192
# Sign up at: https://console.groq.com
# After signup, uncomment and paste your key:
#
# GROQ_API_KEY=gsk_your_key_here

# ── Server settings ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Browser settings ─────────────────────────────────────────────
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════════
#  FREE TIER SUMMARY
#  Component          | API needed? | Cost
#  ─────────────────────────────────────────
#  Browser Agent      | None        | Free (Playwright)
#  Vision Agent       | None        | Free (DOM evaluation)
#  Planner Agent      | None        | Free (regex, default)
#                     | Optional    | Free (Groq llama3-8b)
#  Extraction Agent   | None        | Free (BeautifulSoup)
#  Form Filling Agent | None        | Free (DOM automation)
